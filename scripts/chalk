#!/usr/bin/env bash
# chalk - File-based task management for agents
# Tasks stored as markdown files with YAML frontmatter in .chalk/tasks/
set -euo pipefail

# Locate repo root and tasks directory
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")"
TASKS_DIR="${CHALK_DIR:-$REPO_ROOT/.chalk/tasks}"
CLOSED_DIR="$TASKS_DIR/closed"

# ── Helpers ──────────────────────────────────────────────────────────────────

generate_id() {
    # 4 random hex characters
    local id
    id=$(head -c 2 /dev/urandom | od -An -tx1 | tr -d ' \n' | head -c 4)
    echo "$id"
}

# Read a single scalar field from YAML frontmatter
get_field() {
    local file="$1" field="$2"
    awk -v f="$field" '
        /^---$/ { fm++; next }
        fm == 1 && /^[a-z_]+:/ {
            split($0, a, /: ?/)
            if (a[1] == f) { sub(/^[^:]+: ?/, ""); print; exit }
        }
        fm == 2 { exit }
    ' "$file"
}

# Extract frontmatter from many task files in a SINGLE awk pass and emit one
# tab-separated record per file (avoids spawning awk once per field per file).
# Columns: id<TAB>type<TAB>status<TAB>priority<TAB>parent<TAB>blocked_by<TAB>remote_task_url<TAB>title
# Field parsing mirrors get_field exactly (same delimiter and frontmatter rules).
scan_tasks() {
    [[ $# -gt 0 ]] || return 0
    awk '
        function flush() {
            if (id != "")
                printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n", \
                    id, type, status, priority, parent, blocked, remote, title
        }
        FNR == 1 {
            flush()
            id = FILENAME; sub(/.*\//, "", id); sub(/\.md$/, "", id)
            type = ""; status = ""; priority = ""; parent = ""
            blocked = ""; remote = ""; title = ""; fm = 0
        }
        /^---$/ { fm++; next }
        fm == 1 && /^[a-z_]+:/ {
            split($0, a, /: ?/)
            val = $0; sub(/^[^:]+: ?/, "", val)
            if      (a[1] == "type")            type = val
            else if (a[1] == "status")          status = val
            else if (a[1] == "priority")        priority = val
            else if (a[1] == "parent")          parent = val
            else if (a[1] == "blocked_by")      blocked = val
            else if (a[1] == "remote_task_url") remote = val
            else if (a[1] == "title")           title = val
        }
        END { flush() }
    ' "$@"
}

# Update a frontmatter field in-place (handles special chars in value)
update_field() {
    local file="$1" field="$2" value="$3"
    local tmpfile fm_count=0 found=0
    tmpfile=$(mktemp)
    while IFS= read -r line; do
        if [[ "$line" == "---" ]]; then
            ((fm_count++)) || true
            echo "$line"
            continue
        fi
        if [[ $fm_count -eq 1 ]] && [[ "$line" =~ ^"$field": ]]; then
            echo "$field: $value"
            found=1
        else
            echo "$line"
        fi
    done < "$file" > "$tmpfile"
    if [[ $found -eq 0 ]]; then
        # Field not found — insert before closing --- delimiter
        local insert_tmp
        insert_tmp=$(mktemp)
        local fm2=0
        while IFS= read -r line; do
            if [[ "$line" == "---" ]]; then
                ((fm2++)) || true
                if [[ $fm2 -eq 2 ]]; then
                    echo "$field: $value"
                fi
            fi
            echo "$line"
        done < "$tmpfile" > "$insert_tmp"
        mv "$insert_tmp" "$tmpfile"
    fi
    mv "$tmpfile" "$file"
}

# Find a task file by ID; searches tasks/ then tasks/closed/
find_task() {
    local id="$1"
    local file
    for dir in "$TASKS_DIR" "$CLOSED_DIR"; do
        [[ -d "$dir" ]] || continue
        file="$dir/${id}.md"
        if [[ -f "$file" ]]; then
            echo "$file"
            return 0
        fi
    done
    echo "ERROR: task '$id' not found (searched $TASKS_DIR and $CLOSED_DIR). Run 'chalk list' to see available task IDs." >&2
    return 1
}

now_iso() { date -u +"%Y-%m-%dT%H:%M:%SZ"; }

require_gh() {
    if ! command -v gh &>/dev/null; then
        echo "ERROR: 'gh' CLI is required but not installed." >&2
        echo "Install it from: https://github.com/cli/cli#installation" >&2
        return 1
    fi
    if ! gh auth status &>/dev/null; then
        echo "ERROR: 'gh' CLI is not authenticated. Run 'gh auth login' first." >&2
        return 1
    fi
}

extract_issue_number() {
    local url="$1"
    echo "$url" | grep -oE '/issues/[0-9]+' | grep -oE '[0-9]+'
}

is_github_url() {
    local url="$1"
    [[ "$url" =~ github\.com/.*/issues/[0-9]+ ]]
}

find_task_by_remote_url() {
    local url="$1"
    local f
    for dir in "$TASKS_DIR" "$CLOSED_DIR"; do
        [[ -d "$dir" ]] || continue
        while IFS= read -r -d '' f; do
            if [[ "$(get_field "$f" "remote_task_url")" == "$url" ]]; then
                echo "$f"
                return 0
            fi
        done < <(find "$dir" -maxdepth 1 -name "*.md" -print0 2>/dev/null)
    done
    return 1
}

map_gh_labels_to_type() {
    local labels="$1"
    for t in bug feature chore epic decision; do
        if echo "$labels" | grep -qiw "$t"; then
            echo "$t"
            return
        fi
    done
    echo "task"
}

map_gh_labels_to_priority() {
    local labels="$1"
    if echo "$labels" | grep -qi "critical"; then echo "0"; return; fi
    if echo "$labels" | grep -qiE "high.pri|priority.high|P1|urgent"; then echo "1"; return; fi
    if echo "$labels" | grep -qiE "low.pri|priority.low|P3"; then echo "3"; return; fi
    echo "2"
}

# Update the markdown body (content after second ---) of a task file
update_body() {
    local file="$1" new_body="$2"
    local tmpfile fm_count=0
    tmpfile=$(mktemp)
    while IFS= read -r line; do
        echo "$line"
        if [[ "$line" == "---" ]]; then
            ((fm_count++)) || true
            if [[ $fm_count -eq 2 ]]; then
                break
            fi
        fi
    done < "$file" > "$tmpfile"
    echo "$new_body" >> "$tmpfile"
    mv "$tmpfile" "$file"
}

# Get the markdown body (content after second ---) of a task file
get_body() {
    local file="$1"
    awk '/^---$/{f++; next} f>=2{print}' "$file"
}

VALID_TYPES="task bug feature chore epic decision"
VALID_STATUSES="open in_progress blocked deferred"

validate_type() {
    local t="$1"
    if ! echo "$VALID_TYPES" | grep -qw "$t"; then
        echo "ERROR: invalid type '$t'. Valid types: $VALID_TYPES Example: chalk create \"title\" --type=bug" >&2
        return 1
    fi
}

validate_priority() {
    local p="$1"
    if ! [[ "$p" =~ ^[0-4]$ ]]; then
        echo "ERROR: invalid priority '$p'. Must be 0-4 (0=critical 1=high 2=medium 3=low 4=backlog) Example: chalk update <id> --priority=1" >&2
        return 1
    fi
}

validate_status() {
    local s="$1"
    if ! echo "$VALID_STATUSES" | grep -qw "$s"; then
        echo "ERROR: invalid status '$s'. Valid statuses: $VALID_STATUSES (use 'chalk close' to close a task) Example: chalk update <id> --status=in_progress" >&2
        return 1
    fi
}

print_header() {
    printf "%-20s %-4s %-10s %-12s %-8s %s\n" "ID" "PRI" "TYPE" "STATUS" "REMOTE" "TITLE"
    printf "%-20s %-4s %-10s %-12s %-8s %s\n" "--------------------" "----" "----------" "------------" "--------" "-----"
}

# Render one table row from already-extracted fields (no file re-read).
# Args: id type status priority remote_task_url title
print_task_row() {
    local id="$1" type="$2" status="$3" priority="$4" remote="$5" title="$6"
    local gh_marker=""
    if [[ -n "$remote" && "$remote" != "null" ]]; then
        gh_marker="#$(extract_issue_number "$remote")"
    fi
    printf "%-20s P%-3s %-10s %-12s %-8s %s\n" "$id" "$priority" "$type" "$status" "$gh_marker" "$title"
}

# Build .chalk/task_list.md — a human-readable, flat, priority-sorted list of
# active tasks for browsing the repo without the CLI. Always (re)writes the file.
generate_task_list() {
    [[ -d "$TASKS_DIR" ]] || return 0
    local out_file; out_file="$(dirname "$TASKS_DIR")/task_list.md"
    local tmpfile; tmpfile=$(mktemp)

    {
        echo "<!-- AUTO-GENERATED by chalk — do not edit. Refreshed on every create/update/close/sync while this file exists. -->"
        echo "# Task List"
        echo ""
        echo "_Active tasks, highest priority first. Closed tasks live in .chalk/tasks/closed/._"
        echo ""
    } > "$tmpfile"

    # Collect "priority<TAB>status<TAB>rendered-line" for each active task, then
    # sort by priority (numeric asc) with status as a stable tiebreak. A single
    # scan_tasks (one awk pass) supplies all fields for every file.
    local rows; rows=""
    local -a files=()
    local f
    while IFS= read -r -d '' f; do
        files+=("$f")
    done < <(find "$TASKS_DIR" -maxdepth 1 -name "*.md" -not -name ".gitkeep" -print0 2>/dev/null)
    if [[ ${#files[@]} -gt 0 ]]; then
        local id type status priority parent blocked remote title
        while IFS=$'\t' read -r id type status priority parent blocked remote title; do
            local line="- **${id}** · P${priority} · ${status} · ${title}"
            if [[ -n "$parent" && "$parent" != "null" ]]; then
                line="${line}  (parent: ${parent})"
            fi
            rows+="${priority}	${status}	${line}"$'\n'
        done < <(scan_tasks "${files[@]}")
    fi

    if [[ -z "$rows" ]]; then
        echo "_No active tasks._" >> "$tmpfile"
    else
        printf '%s' "$rows" | sort -t$'\t' -k1,1n -k2,2 | cut -f3- >> "$tmpfile"
    fi

    mv "$tmpfile" "$out_file"
}

# Refresh task_list.md only if it already exists. This keeps the summary opt-in
# (a user enables it via 'chalk tasklist' or 'chalk init'); if absent, mutations
# never recreate it, avoiding unwanted merge-conflict churn.
regenerate_task_list() {
    local out_file; out_file="$(dirname "$TASKS_DIR")/task_list.md"
    [[ -f "$out_file" ]] || return 0
    generate_task_list
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_create() {
    [[ $# -eq 0 ]] && set -- --help

    local title="" type="task" priority="2"
    local labels="[]" blocked_by="[]" parent="null" remote_task_url="null" description=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --type=*)        type="${1#*=}" ;;
            --priority=*)    priority="${1#*=}" ;;
            --labels=*)      labels="[${1#*=}]" ;;
            --blocked_by=*)  blocked_by="[${1#*=}]" ;;
            --parent=*)      parent="${1#*=}" ;;
            --description=*)      description="${1#*=}" ;;
            --remote_task_url=*) remote_task_url="${1#*=}" ;;
            --help|-h)           cat << 'HELP'
chalk create "title" [options]

  --type=TYPE               task|bug|feature|chore|epic|decision (default: task)
  --priority=N              0=critical 1=high 2=medium 3=low 4=backlog (default: 2)
  --description="text"      Optional description (stored in file body)
  --labels=tag1,tag2        Comma-separated labels
  --blocked_by=id1,id2      Comma-separated task IDs that block this task
  --parent=id               Parent task ID (for sub-tasks)

EXAMPLES
  chalk create "Fix login bug" --type=bug --priority=1
  chalk create "Add OAuth support" --type=feature --labels=auth,backend
  chalk create "Write API docs" --parent=epic_a3f2 --priority=3
HELP
                             return 0 ;;
            --*)                 echo "ERROR: unknown option '$1'" >&2; return 1 ;;
            *)               title="$1" ;;
        esac
        shift
    done

    if [[ -z "$title" ]]; then
        echo "ERROR: title is required. Usage: chalk create \"Task title\" [--type=task] [--priority=2] [--description=\"...\"]" >&2
        return 1
    fi

    validate_type "$type" || return 1
    validate_priority "$priority" || return 1

    mkdir -p "$TASKS_DIR"

    # Generate a unique ID
    local id attempts=0
    while true; do
        id="${type}_$(generate_id)"
        if [[ ! -f "$TASKS_DIR/${id}.md" ]] && [[ ! -f "$CLOSED_DIR/${id}.md" ]]; then
            break
        fi
        ((attempts++))
        if [[ $attempts -ge 20 ]]; then
            echo "ERROR: failed to generate unique task ID after 20 attempts" >&2
            return 1
        fi
    done

    local now; now=$(now_iso)
    local body=""
    [[ -n "$description" ]] && body="$description"

    cat > "$TASKS_DIR/${id}.md" << MDEOF
---
id: $id
title: $title
type: $type
status: open
priority: $priority
labels: $labels
blocked_by: $blocked_by
parent: $parent
remote_task_url: $remote_task_url
created_at: $now
updated_at: $now
---
$body
MDEOF

    echo "created: $id"
    regenerate_task_list
}

cmd_show() {
    if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
        cat << 'HELP'
chalk show <id>

Display full details of a task, including all frontmatter fields and description body.

EXAMPLES
  chalk show task_a3f2
  chalk show bug_ed8f
HELP
        [[ $# -eq 0 ]] && return 1 || return 0
    fi

    local file; file=$(find_task "$1") || return 1

    echo "── $(basename "$file" .md) ──"
    # Print frontmatter fields
    awk '/^---$/{f++; next} f==1{print} f==2{exit}' "$file"
    # Print body if non-empty
    local body
    body=$(awk '/^---$/{f++; next} f>=2{print}' "$file" | sed '/^$/d')
    if [[ -n "$body" ]]; then
        echo ""
        echo "── description ──"
        echo "$body"
    fi
}

cmd_list() {
    local filter_status="" filter_type="" filter_priority="" filter_parent="" include_closed=false
    local limit=50 output=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status=*)   filter_status="${1#*=}" ;;
            --type=*)     filter_type="${1#*=}" ;;
            --priority=*) filter_priority="${1#*=}" ;;
            --parent=*)   filter_parent="${1#*=}" ;;
            --closed)     include_closed=true ;;
            --limit=*)    limit="${1#*=}" ;;
            --output=*)   output="${1#*=}" ;;
            --help|-h)    cat << 'HELP'
chalk list [options]

  --status=STATUS           Filter by status (open|in_progress|blocked|deferred)
  --type=TYPE               Filter by type
  --priority=N              Filter by priority (0=critical 1=high 2=medium 3=low 4=backlog)
  --parent=id               Filter by parent task ID
  --closed                  Include closed tasks
  --limit=N                 Max rows to show (default: 50; use 0 for unlimited)
  --output=ids              Emit one task ID per line (machine-readable)

EXAMPLES
  chalk list --status=open --type=bug
  chalk list --priority=0
  chalk list --closed
HELP
                return 0 ;;
            --*)          echo "ERROR: unknown option '$1'. Valid options: --status= --type= --priority= --parent= --closed --limit= --output= Example: chalk list --status=open --type=bug" >&2; return 1 ;;
            *)            echo "ERROR: unexpected argument '$1'" >&2; return 1 ;;
        esac
        shift
    done

    if [[ -n "$output" && "$output" != "ids" ]]; then
        echo "ERROR: invalid --output value '$output'. Valid values: ids" >&2
        return 1
    fi

    [[ -d "$TASKS_DIR" ]] || { echo "No tasks directory found at $TASKS_DIR"; return 0; }

    local -a files=()
    while IFS= read -r -d '' f; do
        files+=("$f")
    done < <(find "$TASKS_DIR" -maxdepth 1 -name "*.md" -not -name ".gitkeep" -print0 2>/dev/null | sort -z)

    if $include_closed && [[ -d "$CLOSED_DIR" ]]; then
        while IFS= read -r -d '' f; do
            files+=("$f")
        done < <(find "$CLOSED_DIR" -maxdepth 1 -name "*.md" -not -name ".gitkeep" -print0 2>/dev/null | sort -z)
    fi

    if [[ ${#files[@]} -eq 0 ]]; then
        echo "no tasks found"
        return 0
    fi

    # Apply filters over a single scan_tasks (one awk pass) and collect matching
    # render records: id<TAB>type<TAB>status<TAB>priority<TAB>remote<TAB>title.
    local -a matched=()
    local id type status priority parent blocked remote title
    while IFS=$'\t' read -r id type status priority parent blocked remote title; do
        [[ -n "$filter_status"   && "$status"   != "$filter_status"   ]] && continue
        [[ -n "$filter_type"     && "$type"     != "$filter_type"     ]] && continue
        [[ -n "$filter_priority" && "$priority" != "$filter_priority" ]] && continue
        [[ -n "$filter_parent"   && "$parent"   != "$filter_parent"   ]] && continue
        matched+=("${id}"$'\t'"${type}"$'\t'"${status}"$'\t'"${priority}"$'\t'"${remote}"$'\t'"${title}")
    done < <(scan_tasks "${files[@]}")

    local total=${#matched[@]}
    if [[ $total -eq 0 ]]; then
        [[ "$output" != "ids" ]] && echo "no tasks match the specified filters"
        return 0
    fi

    # Determine how many to display
    local display_count=$total
    if [[ $limit -gt 0 && $total -gt $limit ]]; then
        display_count=$limit
    fi

    if [[ "$output" == "ids" ]]; then
        local i=0
        while [[ $i -lt $display_count ]]; do
            IFS=$'\t' read -r id _ <<< "${matched[$i]}"
            printf '%s\n' "$id"
            i=$((i + 1))
        done
    else
        print_header
        local i=0
        while [[ $i -lt $display_count ]]; do
            IFS=$'\t' read -r id type status priority remote title <<< "${matched[$i]}"
            print_task_row "$id" "$type" "$status" "$priority" "$remote" "$title"
            i=$((i + 1))
        done
        if [[ $limit -gt 0 && $total -gt $limit ]]; then
            echo "--- showing $limit of $total tasks. Use --status= --type= --priority= --parent= to filter. ---"
        fi
    fi
}

cmd_update() {
    if [[ $# -eq 0 || "$1" == "--help" || "$1" == "-h" ]]; then
        cat << 'HELP'
chalk update <id> [options]

  --status=STATUS           open|in_progress|blocked|deferred
  --priority=N              0=critical 1=high 2=medium 3=low 4=backlog
  --title="new title"
  --type=TYPE               Also renames the file
  --labels=tag1,tag2
  --blocked_by=id1,id2      Set to empty string to clear: --blocked_by=
  --parent=id

EXAMPLES
  chalk update bug_a3f2 --status=in_progress
  chalk update task_ed8f --blocked_by=bug_a3f2
  chalk update task_ed8f --blocked_by=
HELP
        [[ $# -eq 0 ]] && return 1 || return 0
    fi

    local id="$1"; shift
    local file; file=$(find_task "$id") || return 1

    if [[ "$(get_field "$file" "status")" == "closed" ]]; then
        echo "ERROR: task '$id' is closed and cannot be updated. Use 'chalk list --closed' to inspect it, or 'chalk create' to start a new task." >&2
        return 1
    fi

    local updated=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status=*)
                local s="${1#*=}"
                validate_status "$s" || return 1
                update_field "$file" "status" "$s"
                updated=true
                ;;
            --priority=*)
                local p="${1#*=}"
                validate_priority "$p" || return 1
                update_field "$file" "priority" "$p"
                updated=true
                ;;
            --title=*)
                local t="${1#*=}"
                [[ -z "$t" ]] && { echo "ERROR: title cannot be empty" >&2; return 1; }
                update_field "$file" "title" "$t"
                updated=true
                ;;
            --type=*)
                local new_type="${1#*=}"
                validate_type "$new_type" || return 1
                local current_id; current_id=$(get_field "$file" "id")
                local hex="${current_id#*_}"
                local new_id="${new_type}_${hex}"
                local new_file; new_file="$(dirname "$file")/${new_id}.md"
                update_field "$file" "type" "$new_type"
                update_field "$file" "id" "$new_id"
                mv "$file" "$new_file"
                file="$new_file"
                id="$new_id"
                echo "renamed: $current_id → $new_id"
                updated=true
                ;;
            --labels=*)
                local lv="${1#*=}"
                update_field "$file" "labels" "[$lv]"
                updated=true
                ;;
            --blocked_by=*)
                local bv="${1#*=}"
                if [[ -z "$bv" ]]; then
                    update_field "$file" "blocked_by" "[]"
                else
                    update_field "$file" "blocked_by" "[$bv]"
                fi
                updated=true
                ;;
            --parent=*)
                update_field "$file" "parent" "${1#*=}"
                updated=true
                ;;
            --remote_task_url=*)
                update_field "$file" "remote_task_url" "${1#*=}"
                updated=true
                ;;
            --help|-h)
                cat << 'HELP'
chalk update <id> [options]

  --status=STATUS           open|in_progress|blocked|deferred
  --priority=N              0=critical 1=high 2=medium 3=low 4=backlog
  --title="new title"
  --type=TYPE               Also renames the file
  --labels=tag1,tag2
  --blocked_by=id1,id2      Set to empty string to clear: --blocked_by=
  --parent=id

EXAMPLES
  chalk update bug_a3f2 --status=in_progress
  chalk update task_ed8f --blocked_by=bug_a3f2
  chalk update task_ed8f --blocked_by=
HELP
                return 0 ;;
            --*)
                echo "ERROR: unknown option '$1'. Valid options: --status= --priority= --title= --type= --labels= --blocked_by= --parent= --remote_task_url= Example: chalk update <id> --status=in_progress" >&2
                return 1
                ;;
            *)
                echo "ERROR: unexpected argument '$1'" >&2
                return 1
                ;;
        esac
        shift
    done

    if ! $updated; then
        echo "ERROR: no updates specified. Use --status= --priority= --title= --type= --labels= --blocked_by= --parent= --remote_task_url=" >&2
        return 1
    fi

    update_field "$file" "updated_at" "$(now_iso)"
    echo "updated: $id"
    regenerate_task_list
}

cmd_close() {
    if [[ $# -eq 0 ]]; then
        echo "ERROR: task ID required. Usage: chalk close <id>" >&2
        return 1
    fi

    local id="$1"
    local file; file=$(find_task "$id") || return 1

    if [[ "$(get_field "$file" "status")" == "closed" ]]; then
        echo "ERROR: task '$id' is already closed. Use 'chalk list --closed' to see closed tasks." >&2
        return 1
    fi

    mkdir -p "$CLOSED_DIR"
    local now; now=$(now_iso)
    update_field "$file" "status" "closed"
    update_field "$file" "updated_at" "$now"

    local filename; filename=$(basename "$file")
    mv "$file" "$CLOSED_DIR/$filename"

    echo "closed: $id"
    echo "moved to: $CLOSED_DIR/$filename"

    # Auto-unblock: scan active tasks that list this id in blocked_by
    while IFS= read -r -d '' dependent; do
        local raw_blocked; raw_blocked=$(get_field "$dependent" "blocked_by")
        # Skip if blocked_by is empty or []
        [[ "$raw_blocked" == "[]" || -z "$raw_blocked" ]] && continue
        # Check if this closed id appears in the list
        if echo "$raw_blocked" | grep -qw "$id"; then
            # Remove the closed id from the list
            local new_blocked
            # Use awk (not grep -v) so exit code is 0 even when all entries are removed
            new_blocked=$(echo "$raw_blocked" | tr -d '[]' | tr ',' '\n' | \
                awk -v id="$id" 'NF && $0 != id' | tr '\n' ',' | sed 's/^,//;s/,$//')
            local dep_id; dep_id=$(basename "$dependent" .md)
            local dep_title; dep_title=$(get_field "$dependent" "title")
            if [[ -z "$new_blocked" ]]; then
                update_field "$dependent" "blocked_by" "[]"
                # If task was blocked, flip it back to open
                if [[ "$(get_field "$dependent" "status")" == "blocked" ]]; then
                    update_field "$dependent" "status" "open"
                    update_field "$dependent" "updated_at" "$now"
                    echo "unblocked: $dep_id \"$dep_title\" (status → open)"
                else
                    update_field "$dependent" "updated_at" "$now"
                    echo "unblocked: $dep_id \"$dep_title\""
                fi
            else
                update_field "$dependent" "blocked_by" "[$new_blocked]"
                update_field "$dependent" "updated_at" "$now"
                echo "unblocked: $dep_id \"$dep_title\" (still blocked by: $new_blocked)"
            fi
        fi
    done < <(find "$TASKS_DIR" -maxdepth 1 -name "*.md" -not -name ".gitkeep" -print0 2>/dev/null)

    # Epic completion: if the closed task belongs to a parent, check if all siblings are now closed
    local parent; parent=$(get_field "$CLOSED_DIR/$filename" "parent")
    if [[ -n "$parent" && "$parent" != "null" ]]; then
        local remaining=0
        while IFS= read -r -d '' sibling; do
            local sib_parent; sib_parent=$(get_field "$sibling" "parent")
            [[ "$sib_parent" == "$parent" ]] && ((remaining++)) || true
        done < <(find "$TASKS_DIR" -maxdepth 1 -name "*.md" -not -name ".gitkeep" -print0 2>/dev/null)

        if [[ $remaining -eq 0 ]]; then
            local parent_file parent_title=""
            if parent_file=$(find_task "$parent" 2>/dev/null); then
                parent_title=$(get_field "$parent_file" "title")
                echo "complete: $parent \"$parent_title\" — no open sub-tasks remaining"
            else
                echo "complete: $parent — no open sub-tasks remaining"
            fi
        fi
    fi

    regenerate_task_list
}

cmd_ready() {
    local filter_parent="" output=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --parent=*)  filter_parent="${1#*=}" ;;
            --output=*)  output="${1#*=}" ;;
            --help|-h)   cat << 'HELP'
chalk ready [options]

Show open, unblocked tasks sorted by priority.

  --parent=id               Filter by parent task ID
  --output=ids              Emit one task ID per line (machine-readable)

EXAMPLES
  chalk ready
  chalk ready --parent=epic_a3f2
  chalk ready --output=ids
HELP
                return 0 ;;
            --*)         echo "ERROR: unknown option '$1'. Valid options: --parent= --output=" >&2; return 1 ;;
            *)           echo "ERROR: unexpected argument '$1'" >&2; return 1 ;;
        esac
        shift
    done

    if [[ -n "$output" && "$output" != "ids" ]]; then
        echo "ERROR: invalid --output value '$output'. Valid values: ids" >&2
        return 1
    fi

    [[ -d "$TASKS_DIR" ]] || { echo "no tasks directory found at $TASKS_DIR"; return 0; }

    # Collect open, unblocked tasks via a single scan_tasks (one awk pass) into
    # sortable records: priority<TAB>id<TAB>type<TAB>status<TAB>remote<TAB>title.
    local -a files=()
    local f
    while IFS= read -r -d '' f; do
        files+=("$f")
    done < <(find "$TASKS_DIR" -maxdepth 1 -name "*.md" -not -name ".gitkeep" -print0 2>/dev/null)

    local -a pairs=()
    if [[ ${#files[@]} -gt 0 ]]; then
        local id type status priority parent blocked remote title
        while IFS=$'\t' read -r id type status priority parent blocked remote title; do
            [[ "$status" == "open" ]] || continue
            [[ -z "$blocked" || "$blocked" == "[]" ]] || continue
            [[ -n "$filter_parent" && "$parent" != "$filter_parent" ]] && continue
            pairs+=("${priority}"$'\t'"${id}"$'\t'"${type}"$'\t'"${status}"$'\t'"${remote}"$'\t'"${title}")
        done < <(scan_tasks "${files[@]}")
    fi

    if [[ ${#pairs[@]} -eq 0 ]]; then
        [[ "$output" != "ids" ]] && echo "no open tasks"
        return 0
    fi

    # Sort by priority (numerically)
    local -a sorted
    IFS=$'\n' read -r -d '' -a sorted < <(printf '%s\n' "${pairs[@]}" | sort -t$'\t' -k1,1n && printf '\0') || true

    local prio id type status remote title
    if [[ "$output" == "ids" ]]; then
        for pair in "${sorted[@]}"; do
            IFS=$'\t' read -r prio id _ <<< "$pair"
            printf '%s\n' "$id"
        done
    else
        print_header
        for pair in "${sorted[@]}"; do
            IFS=$'\t' read -r prio id type status remote title <<< "$pair"
            print_task_row "$id" "$type" "$status" "$prio" "$remote" "$title"
        done
    fi
}

cmd_tasklist() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --help|-h) cat << 'HELP'
chalk tasklist

Generate (or refresh) .chalk/task_list.md — a human-readable, priority-sorted
list of active tasks for browsing the repo without the CLI.

Once the file exists, it is refreshed automatically on every create/update/close
and ghi clone/push/sync. Delete the file to opt out (mutations won't recreate it).

EXAMPLES
  chalk tasklist
HELP
                return 0 ;;
            --*) echo "ERROR: unknown option '$1'. Valid options: --help Example: chalk tasklist" >&2; return 1 ;;
            *)   echo "ERROR: unexpected argument '$1'. Usage: chalk tasklist" >&2; return 1 ;;
        esac
        shift
    done

    if [[ ! -d "$TASKS_DIR" ]]; then
        echo "ERROR: no tasks directory found at $TASKS_DIR. Run 'chalk init' first." >&2
        return 1
    fi

    generate_task_list
    echo "wrote: $(dirname "$TASKS_DIR")/task_list.md"
}

cmd_ghi() {
    require_gh || return 1

    if [[ $# -eq 0 ]]; then
        echo "ERROR: subcommand required. Usage: chalk ghi {clone|sync|push}" >&2
        return 1
    fi

    local subcmd="$1"; shift
    case "$subcmd" in
        clone) ghi_clone "$@" ;;
        sync)  ghi_sync  "$@" ;;
        push)  ghi_push  "$@" ;;
        *)     echo "ERROR: unknown ghi subcommand '$subcmd'. Valid: clone sync push" >&2; return 1 ;;
    esac
}

ghi_clone() {
    local limit=500
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --limit=*) limit="${1#*=}" ;;
            --help|-h) cat << 'HELP'
chalk ghi clone [options]

Clone open GitHub issues as local tasks. Already-cloned issues are skipped.

  --limit=N                 Max issues to fetch (default: 500)

EXAMPLES
  chalk ghi clone
  chalk ghi clone --limit=100
HELP
                return 0 ;;
            *) echo "ERROR: unknown option '$1'" >&2; return 1 ;;
        esac
        shift
    done

    mkdir -p "$TASKS_DIR"

    local cloned=0 skipped=0
    while IFS=$'\t' read -r url title labels_csv body; do
        # Skip if already cloned
        if find_task_by_remote_url "$url" &>/dev/null; then
            ((skipped++)) || true
            continue
        fi

        local type; type=$(map_gh_labels_to_type "$labels_csv")
        local priority; priority=$(map_gh_labels_to_priority "$labels_csv")

        # Filter out type/priority labels, keep the rest
        local filtered_labels=""
        if [[ -n "$labels_csv" ]]; then
            filtered_labels=$(echo "$labels_csv" | tr ',' '\n' | \
                grep -ivE "^(bug|feature|chore|epic|decision|critical|urgent|P[0-4])$" | \
                tr '\n' ',' | sed 's/,$//')
        fi

        local id
        while true; do
            id="${type}_$(generate_id)"
            [[ ! -f "$TASKS_DIR/${id}.md" && ! -f "$CLOSED_DIR/${id}.md" ]] && break
        done

        local now; now=$(now_iso)
        local labels_field="[${filtered_labels}]"

        cat > "$TASKS_DIR/${id}.md" << MDEOF
---
id: $id
title: $title
type: $type
status: open
priority: $priority
labels: $labels_field
blocked_by: []
parent: null
remote_task_url: $url
created_at: $now
updated_at: $now
---
$body
MDEOF
        echo "cloned: $id <- $url"
        ((cloned++)) || true
    done < <(gh issue list --state open --json url,title,labels,body --limit "$limit" \
        --jq '.[] | [.url, .title, (.labels | map(.name) | join(",")), (.body // "")] | @tsv')

    echo "clone complete: $cloned cloned, $skipped skipped (already exist)"
    regenerate_task_list
}

ghi_push() {
    local all=false task_id=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -a|--all)  all=true ;;
            --help|-h) cat << 'HELP'
chalk ghi push <id> [options]

Push a local task to GitHub as a new issue.

  -a, --all                 Push all tasks that don't yet have a remote URL

EXAMPLES
  chalk ghi push task_a3f2
  chalk ghi push --all
HELP
                return 0 ;;
            --*) echo "ERROR: unknown option '$1'" >&2; return 1 ;;
            *)   task_id="$1" ;;
        esac
        shift
    done

    if [[ -z "$task_id" ]] && ! $all; then
        echo "ERROR: task ID required. Usage: chalk ghi push <id> [--all]. Run 'chalk ghi push --help' for details." >&2
        return 1
    fi

    local -a files=()
    if $all; then
        [[ -d "$TASKS_DIR" ]] || { echo "no tasks directory"; return 0; }
        while IFS= read -r -d '' f; do
            local url; url=$(get_field "$f" "remote_task_url")
            [[ -z "$url" || "$url" == "null" ]] && files+=("$f")
        done < <(find "$TASKS_DIR" -maxdepth 1 -name "*.md" -print0 2>/dev/null)
    else
        local f; f=$(find_task "$task_id") || return 1
        local url; url=$(get_field "$f" "remote_task_url")
        if [[ -n "$url" && "$url" != "null" ]]; then
            echo "ERROR: task '$task_id' already has a remote URL: $url" >&2
            return 1
        fi
        files+=("$f")
    fi

    if [[ ${#files[@]} -eq 0 ]]; then
        echo "no tasks to push (all tasks already have remote URLs)"
        return 0
    fi

    local pushed=0
    for file in "${files[@]}"; do
        local id; id=$(basename "$file" .md)
        local title; title=$(get_field "$file" "title")
        local type; type=$(get_field "$file" "type")
        local labels; labels=$(get_field "$file" "labels")
        local body; body=$(get_body "$file")

        local -a gh_args=(--title "$title")
        gh_args+=(--body "${body:-}")

        # Collect all labels (type + user labels)
        local -a all_labels=("$type")
        local raw_labels
        raw_labels=$(echo "$labels" | tr -d '[]' | sed 's/^ *//;s/ *$//')
        if [[ -n "$raw_labels" ]]; then
            IFS=',' read -ra label_arr <<< "$raw_labels"
            for lbl in "${label_arr[@]}"; do
                lbl=$(echo "$lbl" | sed 's/^ *//;s/ *$//')
                [[ -n "$lbl" ]] && all_labels+=("$lbl")
            done
        fi

        # Ensure labels exist on the repo, create if missing
        for lbl in "${all_labels[@]}"; do
            gh label create "$lbl" --force &>/dev/null || true
            gh_args+=(--label "$lbl")
        done

        local issue_url
        if ! issue_url=$(gh issue create "${gh_args[@]}" 2>&1); then
            echo "ERROR: failed to create issue for $id: $issue_url" >&2
            continue
        fi

        update_field "$file" "remote_task_url" "$issue_url"
        update_field "$file" "updated_at" "$(now_iso)"
        echo "pushed: $id -> $issue_url"
        ((pushed++)) || true
    done

    echo "push complete: $pushed pushed"
    regenerate_task_list
}

ghi_sync() {
    local task_id=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --*) echo "ERROR: unknown option '$1'" >&2; return 1 ;;
            *)   task_id="$1" ;;
        esac
        shift
    done

    local -a files=()
    if [[ -n "$task_id" ]]; then
        local f; f=$(find_task "$task_id") || return 1
        files+=("$f")
    else
        for dir in "$TASKS_DIR" "$CLOSED_DIR"; do
            [[ -d "$dir" ]] || continue
            while IFS= read -r -d '' f; do
                local url; url=$(get_field "$f" "remote_task_url")
                [[ -n "$url" && "$url" != "null" ]] && is_github_url "$url" && files+=("$f")
            done < <(find "$dir" -maxdepth 1 -name "*.md" -print0 2>/dev/null)
        done
    fi

    if [[ ${#files[@]} -eq 0 ]]; then
        echo "no tasks with GitHub remote_task_url found"
        return 0
    fi

    local synced=0 errors=0
    for file in "${files[@]}"; do
        local url; url=$(get_field "$file" "remote_task_url")
        local issue_num; issue_num=$(extract_issue_number "$url")
        local id; id=$(basename "$file" .md)

        local gh_title gh_state gh_labels gh_body gh_updated
        local issue_tsv
        if ! issue_tsv=$(gh issue view "$issue_num" --json title,state,labels,body,updatedAt \
            --jq '[.title, .state, ([.labels[].name] | join(",")), .updatedAt, (.body // "")] | @tsv' 2>&1); then
            echo "ERROR: failed to fetch issue #$issue_num for task $id: $issue_tsv" >&2
            ((errors++)) || true
            continue
        fi

        IFS=$'\t' read -r gh_title gh_state gh_labels gh_updated gh_body <<< "$issue_tsv"

        local local_updated; local_updated=$(get_field "$file" "updated_at")
        local current_status; current_status=$(get_field "$file" "status")

        # Compare timestamps to determine sync direction
        # Normalize to epoch for comparison
        local local_epoch gh_epoch
        local_epoch=$(date -jf "%Y-%m-%dT%H:%M:%SZ" "$local_updated" +%s 2>/dev/null || date -d "$local_updated" +%s 2>/dev/null || echo "0")
        gh_epoch=$(date -jf "%Y-%m-%dT%H:%M:%SZ" "$gh_updated" +%s 2>/dev/null || date -d "$gh_updated" +%s 2>/dev/null || echo "0")

        if [[ "$gh_epoch" -ge "$local_epoch" ]]; then
            # Remote is newer — pull changes to local
            update_field "$file" "title" "$gh_title"

            # Update labels (filter out type/priority labels)
            if [[ -n "$gh_labels" ]]; then
                local filtered
                filtered=$(echo "$gh_labels" | tr ',' '\n' | \
                    grep -ivE "^(bug|feature|chore|epic|decision|critical|urgent|P[0-4])$" | \
                    tr '\n' ',' | sed 's/,$//')
                update_field "$file" "labels" "[$filtered]"
            fi

            # Update body
            update_body "$file" "$gh_body"

            # Handle status
            if [[ "$gh_state" == "CLOSED" && "$current_status" != "closed" ]]; then
                update_field "$file" "status" "closed"
                update_field "$file" "updated_at" "$(now_iso)"
                mkdir -p "$CLOSED_DIR"
                mv "$file" "$CLOSED_DIR/$(basename "$file")"
                echo "synced: $id (closed from remote)"
            elif [[ "$gh_state" == "OPEN" && "$current_status" == "closed" ]]; then
                update_field "$file" "status" "open"
                update_field "$file" "updated_at" "$(now_iso)"
                mv "$file" "$TASKS_DIR/$(basename "$file")"
                echo "synced: $id (reopened from remote)"
            else
                update_field "$file" "updated_at" "$(now_iso)"
                echo "synced: $id (pulled from remote)"
            fi
        else
            # Local is newer — push changes to remote
            local local_title; local_title=$(get_field "$file" "title")
            local local_body; local_body=$(get_body "$file")
            local local_labels; local_labels=$(get_field "$file" "labels")

            # Build edit args
            local -a edit_args=()
            edit_args+=(--title "$local_title")
            if [[ -n "$local_body" ]]; then
                edit_args+=(--body "$local_body")
            fi

            gh issue edit "$issue_num" "${edit_args[@]}" &>/dev/null || true

            # Handle status changes
            if [[ "$current_status" == "closed" && "$gh_state" == "OPEN" ]]; then
                gh issue close "$issue_num" &>/dev/null || true
                echo "synced: $id (closed on remote)"
            elif [[ "$current_status" != "closed" && "$gh_state" == "CLOSED" ]]; then
                gh issue reopen "$issue_num" &>/dev/null || true
                echo "synced: $id (reopened on remote)"
            else
                echo "synced: $id (pushed to remote)"
            fi

            update_field "$file" "updated_at" "$(now_iso)"
        fi
        ((synced++)) || true
    done

    echo "sync complete: $synced synced, $errors errors"
    regenerate_task_list
}

cmd_init() {
    local make_task_list=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-task-list) make_task_list=false ;;
            --help|-h) cat << 'HELP'
chalk init [options]

Create .chalk/tasks/ and .chalk/tasks/closed/ at the repo root, and seed an
initial .chalk/task_list.md summary.

  --no-task-list            Don't create task_list.md (opt out of the summary,
                            e.g. to avoid merge-conflict churn)

EXAMPLES
  chalk init
  chalk init --no-task-list
HELP
                return 0 ;;
            --*) echo "ERROR: unknown option '$1'. Valid options: --no-task-list Example: chalk init --no-task-list" >&2; return 1 ;;
            *)   echo "ERROR: unexpected argument '$1'. Usage: chalk init [--no-task-list]" >&2; return 1 ;;
        esac
        shift
    done

    local repo_root
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"

    if [[ -z "$repo_root" ]]; then
        echo "WARNING: not inside a git repository. Initializing in current directory." >&2
        repo_root="$PWD"
    elif [[ "$repo_root" != "$PWD" ]]; then
        echo "ERROR: run 'chalk init' from the repo root." >&2
        echo "  Repo root: $repo_root" >&2
        echo "  Current dir: $PWD" >&2
        return 1
    fi

    local tasks_dir="${CHALK_DIR:-$repo_root/.chalk/tasks}"

    if [[ -d "$tasks_dir" ]]; then
        echo "chalk already initialized ($tasks_dir)"
        return 0
    fi

    mkdir -p "$tasks_dir/closed"
    echo "initialized chalk at $tasks_dir"

    if $make_task_list; then
        generate_task_list
        echo "created task list at $(dirname "$tasks_dir")/task_list.md"
    fi
}

cmd_help() {
    cat << 'HELP'
chalk - file-based task management

USAGE
  chalk <command> [args]

COMMANDS
  init                Initialize chalk in the current git repo
  create              Create a new task
  show                Display full task details
  list                List tasks
  update              Update task fields
  close               Mark task closed and move to .chalk/tasks/closed/
  ready               Show open tasks sorted by priority
  tasklist            Generate/refresh .chalk/task_list.md (human-readable summary)
  ghi clone           Clone open GitHub issues as local tasks
  ghi push            Push a local task to GitHub as a new issue
  ghi sync            Bidirectional sync with linked GitHub issues

HELP
}

# ── Entry point ───────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
    cmd_help
    exit 0
fi

cmd="$1"

# Help commands are for humans — no footer
case "$cmd" in
    help|--help|-h)
        shift
        cmd_help
        exit 0
        ;;
esac

# Record start time and install EXIT trap for metadata footer
_CHALK_START=$SECONDS
_chalk_exit_footer() {
    local code=$?
    local elapsed=$(( (SECONDS - _CHALK_START) * 1000 ))
    echo "[exit:${code} | ${elapsed}ms]"
}
trap _chalk_exit_footer EXIT

shift
case "$cmd" in
    init)   cmd_init   "$@" ;;
    create) cmd_create "$@" ;;
    show)   cmd_show   "$@" ;;
    list)   cmd_list   "$@" ;;
    update) cmd_update "$@" ;;
    close)  cmd_close  "$@" ;;
    ready)  cmd_ready  "$@" ;;
    tasklist) cmd_tasklist "$@" ;;
    ghi)    cmd_ghi    "$@" ;;
    *)
        echo "ERROR: unknown command '$cmd'. Run 'chalk help' for usage." >&2
        exit 1
        ;;
esac
